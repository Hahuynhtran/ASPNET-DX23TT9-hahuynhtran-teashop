@model IEnumerable<TeaShopWeb.Models.Product>

@{
    ViewBag.Title = "Danh sách sản phẩm";
}

<div class="container mt-4">
    <h2 class="text-center text-primary mb-4">@ViewBag.Title</h2>

    <!-- Thanh tìm kiếm và bộ lọc -->
    <div class="row mb-4">
        <div class="col-md-8">
            @using (Html.BeginForm("Index", "Product", FormMethod.Get, new { @class = "d-flex" }))
            {
                <div class="input-group">
                    <input type="text" name="searchTerm" class="form-control" placeholder="Tìm kiếm sản phẩm..." value="@ViewBag.SearchTerm" />
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-search"></i> Tìm kiếm
                    </button>
                </div>
            }
        </div>
        <div class="col-md-4">
            @using (Html.BeginForm("Index", "Product", FormMethod.Get, new { @class = "d-flex" }))
            {
                <div class="input-group">
                    <select name="categoryId" class="form-select">
                        <option value="">Tất cả danh mục</option>
                        @foreach (var category in ViewBag.Categories)
                        {
                            <option value="@category.Id" selected="@(ViewBag.SelectedCategory == category.Id)">@category.CategoryName</option>
                        }
                    </select>
                    <button type="submit" class="btn btn-outline-secondary">Lọc</button>
                </div>
            }
        </div>
    </div>

    <!-- Danh sách sản phẩm -->
    <div class="row">
        @foreach (var product in Model)
        {
            <div class="col-md-3 col-sm-6 mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/products/default.jpg" : product.ImageUrl)"
                         class="card-img-top" alt="@product.ProductName" style="height: 200px; object-fit: cover;" />
                    <div class="card-body">
                        <h5 class="card-title text-truncate">@product.ProductName</h5>
                        <p class="card-text text-danger fw-bold">@String.Format("{0:N0}", product.Price) VNĐ</p>
                        <p class="card-text"><small class="text-muted">@(product.Category?.CategoryName ?? "Không có danh mục")</small></p>
                    </div>
                    <div class="card-footer bg-transparent border-0">
                        <a href="@Url.Action("Details", new { id = product.Id })" class="btn btn-outline-primary w-100">
                            <i class="fas fa-eye"></i> Xem chi tiết
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-info-circle"></i> Không tìm thấy sản phẩm nào.
        </div>
    }
</div>