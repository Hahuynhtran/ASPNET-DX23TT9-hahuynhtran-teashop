@{
    ViewBag.Title = "Trà Sữa Thốt Nốt - Trang chủ";
}

<div class="jumbotron text-center" style="background-color: #FFF8E7; border-radius: 20px; padding: 40px;">
    <h1 style="color: #5D4037;">🧋 Chào mừng đến với Trà Sữa Thốt Nốt</h1>
    <p class="lead" style="color: #8B5E3C;">Hương vị thốt nốt quê hương – Đậm đà khó quên</p>
    <p>
        <a href="@Url.Action("Index", "Product")" class="btn btn-primary btn-lg" style="background-color: #8B5E3C; border-color: #8B5E3C;">
            🛒 Xem thực đơn ngay
        </a>
    </p>
</div>

<div class="row text-center">
    <div class="col-md-4">
        <div class="card" style="border: 1px solid #e0d5c1; border-radius: 15px; padding: 20px; margin-bottom: 20px;">
            <i class="fas fa-coffee" style="font-size: 3rem; color: #8B5E3C;"></i>
            <h3>Nguyên liệu tự nhiên</h3>
            <p>Thốt nốt tươi từ Trà Vinh, đảm bảo chất lượng.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card" style="border: 1px solid #e0d5c1; border-radius: 15px; padding: 20px; margin-bottom: 20px;">
            <i class="fas fa-truck" style="font-size: 3rem; color: #8B5E3C;"></i>
            <h3>Giao hàng nhanh</h3>
            <p>Miễn phí giao hàng trong khu vực nội thành Trà Vinh.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card" style="border: 1px solid #e0d5c1; border-radius: 15px; padding: 20px; margin-bottom: 20px;">
            <i class="fas fa-star" style="font-size: 3rem; color: #8B5E3C;"></i>
            <h3>Đánh giá cao</h3>
            <p>Được sinh viên Đại học Trà Vinh yêu thích nhất 2026.</p>
        </div>
    </div>
</div>