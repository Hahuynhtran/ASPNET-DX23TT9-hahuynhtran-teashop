@model TeaShopWeb.Models.Product

@{
    ViewBag.Title = "Chi tiết sản phẩm";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">@Html.ActionLink("Trang chủ", "Index", "Home")</li>
            <li class="breadcrumb-item">@Html.ActionLink("Sản phẩm", "Index", "Product")</li>
            <li class="breadcrumb-item active" aria-current="page">@Model.ProductName</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-5">
            <div class="card">
                <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/products/default.jpg" : Model.ImageUrl)"
                     class="card-img-top" alt="@Model.ProductName" style="height: 400px; object-fit: contain;" />
            </div>
        </div>

        <div class="col-md-7">
            <h2 class="fw-bold">@Model.ProductName</h2>
            <p class="text-muted">@(Model.Category?.CategoryName ?? "Không có danh mục")</p>
            <hr />
            <h3 class="text-danger fw-bold">@String.Format("{0:N0}", Model.Price) VNĐ</h3>

            <div class="mt-4">
                <h5>Mô tả sản phẩm</h5>
                <p>@(string.IsNullOrEmpty(Model.Description) ? "Chưa có mô tả" : Model.Description)</p>
            </div>

            <div class="mt-4">
                <label class="fw-bold">Số lượng tồn kho: </label>
                <span class="badge bg-@(Model.StockQuantity > 0 ? "success" : "danger")">
                    @(Model.StockQuantity > 0 ? $"{Model.StockQuantity} sản phẩm" : "Hết hàng")
                </span>
            </div>

            <div class="mt-4">
                <div class="row">
                    <div class="col-md-4">
                        <label class="fw-bold">Chọn size:</label>
                        <select id="sizeSelect" class="form-select">
                            <option value="0" data-price="0">S - Nhỏ (không phụ phí)</option>
                            <option value="1" data-price="5000">M - Vừa (+5,000 VNĐ)</option>
                            <option value="2" data-price="10000">L - Lớn (+10,000 VNĐ)</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="fw-bold">Số lượng:</label>
                        <input type="number" id="quantityInput" class="form-control" value="1" min="1" max="@Model.StockQuantity" />
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <button id="addToCartBtn" class="btn btn-success btn-lg w-100" @(Model.StockQuantity == 0 ? "disabled" : "")>
                    <i class="fas fa-cart-plus"></i> Thêm vào giỏ hàng
                </button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            $('#addToCartBtn').click(function (e) {
                e.preventDefault(); // ngăn chặn hành vi mặc định nếu có
                var productId = @Model.Id;
                var sizeId = parseInt($('#sizeSelect').val()) || 0;
                var quantity = parseInt($('#quantityInput').val()) || 1;

                $.ajax({
                    url: '@Url.Action("AddToCart", "Cart")',
                    type: 'POST',
                    data: {
                        productId: productId,
                        sizeId: sizeId,
                        quantity: quantity
                    },
                    success: function (response) {
                        if (response.success) {
                            alert('Đã thêm vào giỏ hàng!');
                            $('#cart-count').text(response.cartCount).show();
                        } else {
                            alert('Lỗi: ' + response.message);
                        }
                    },
                    error: function (xhr, status, error) {
                        console.log(xhr.responseText);
                        alert('Có lỗi xảy ra, vui lòng thử lại!');
                    }
                });
            });
        });
    </script>
}